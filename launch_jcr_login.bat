@echo off
node -e "const { chromium } = require('playwright-extra'); const stealth = require('puppeteer-extra-plugin-stealth')(); chromium.use(stealth); (async () => { console.log('=================================================='); console.log('Launching JCR Institutional Login Assistant...'); console.log('=================================================='); const context = await chromium.launchPersistentContext('./.playwright_profile', { headless: false, viewport: null, args: ['--disable-blink-features=AutomationControlled', '--test-type'] }); const page = await context.newPage(); await page.goto('https://jcr.clarivate.com/jcr/home'); console.log('\n[INSTRUCTIONS]\n1. Log into your institution Clarivate/JCR subscription account.\n2. Verify you can search journals.\n3. Close this browser window to save cookies locally.\n'); while (context.pages().length > 0) { await new Promise(r => setTimeout(r, 1000)); } console.log('Login window closed. Cookies saved in local .playwright_profile. Do not commit that folder.'); })();"
