# ORCID API Configuration
# Replace these placeholder values with your actual ORCID Client credentials.
# You can obtain a free Public Client ID and Client Secret by registering on your ORCID developer tools page.
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=00000000-0000-0000-0000-000000000000

# Target scholar's ORCID iD to scrape (e.g., 0000-0002-1825-0097)
TARGET_ORCID_ID=0000-0002-1825-0097

# Optional: Output CSV file name (defaults to orcid_publications.csv)
OUTPUT_CSV=orcid_publications.csv

# Optional Clarivate/JCR credentials for local use only.
# Prefer setting these in your shell instead of committing config files.
CLARIVATE_EMAIL=your_email@institution.edu
CLARIVATE_PASSWORD=your_password
